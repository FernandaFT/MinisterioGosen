@model UsuarioModel

@{
    var nombre = Context.Session.GetString("Nombre");
    var idRol = Context.Session.GetInt32("Id_Rol");

    var rol = idRol == 1 ? "Administrador" : "Usuario";

    ViewData["Title"] = "Configuración";
    Layout = "_Layout";
}

<section class="container-fluid configuracion-section py-5">
    <div class="container py-lg-4">

        <!-- Encabezado -->
        <div class="configuracion-encabezado text-center mb-4 wow " >
            <p class="configuracion-subtitulo text-uppercase fw-bold mb-2">Mi cuenta</p>
            <h1 class="configuracion-titulo fw-bold mb-2">Configuración del perfil</h1>
            <p class="configuracion-descripcion mb-0">Actualizá tu información personal y administrá la seguridad de tu cuenta.</p>
        </div>

        <!-- Perfil del usuario -->
        <div class="row mb-4">
            <div class="col-12 wow">
                <div class="card perfil-card">
                    <div class="card-body p-4 p-lg-5">

                        <div class="perfil-contenido d-flex align-items-center">

                            <div class="perfil-icono me-md-4 mb-3 mb-md-0">
                                <i class="fas fa-user"></i>
                            </div>

                            <div class="perfil-informacion">

                                <p class="perfil-etiqueta mb-1 text-uppercase">Perfil de usuario</p>

                                <h2 class="perfil-nombre">
                                    @(string.IsNullOrWhiteSpace(nombre) ? "Usuario" : nombre)
                                </h2>

                                <p class="perfil-rol">
                                    <i class="fas fa-user-shield me-2"></i>
                                    Rol: @rol
                                </p>

                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Formularios -->
        <div class="row g-4 align-items-stretch">

            <!-- Información personal -->
            <div class="col-lg-6 wow ">
                <div class="card config-card">

                    <div class="config-card-header">

                        @if (ViewBag.MensajePerfil != null)
                        {
                            <div class="alert alert-warning" role="alert" mb-4">
                                @ViewBag.MensajePerfil
                            </div>
                        }

                        <div class="d-flex align-items-center">

                            <div class="config-card-icon me-3">
                                <i class="fas fa-address-card"></i>
                            </div>

                            <div>
                                <h3 class="config-card-title">Información personal</h3>
                                <p class="config-card-description">Modificá los datos principales de tu perfil.</p>
                            </div>

                        </div>
                    </div>

                    <div class="config-card-body">

                        <form id="ConfirmarInfoPersonal" class="config-form" asp-action="CambiarPerfil" asp-controller="Usuario" method="post">

                            <div class="row g-4">

                                <div class="col-12">
                                    <div class="form-floating">
                                        <input asp-for="Identificacion" type="text" class="form-control" placeholder="Identificación"/>
                                        <label>Identificación</label>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-floating">
                                        <input asp-for="Nombre" type="text" class="form-control" placeholder="Nombre completo"/>
                                        <label>Nombre completo</label>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-floating">
                                        <input asp-for="Correo" type="email" class="form-control" placeholder="Correo Electrónico"/>
                                        <label>Correo Electrónico</label>
                                    </div>
                                </div>

                                <div class="col-12 mt-4">
                                    <button type="submit" class="btn btn-configuracion w-100">
                                        Guardar información
                                    </button>
                                </div>

                            </div>
                        </form>
                    </div>

                </div>
            </div>

            <!-- Cambio de contraseña -->
            <div class="col-lg-6 wow">
                <div class="card config-card">

                    <div class="config-card-header">

                        
                        @if (ViewBag.MensajeContrasena != null)
                        {
                            <div class="alert alert-warning mb-4" role="alert">
                                @ViewBag.MensajeContrasena
                            </div>
                        }

                        <div class="d-flex align-items-center">

                            <div class="config-card-icon me-3">
                                <i class="fas fa-lock"></i>
                            </div>

                            <div>
                                <h3 class="config-card-title">Cambio de contraseña</h3>
                                <p class="config-card-description">Creá una contraseña segura para proteger tu cuenta.</p>
                            </div>

                        </div>
                    </div>

                    <div class="config-card-body">

                        <form id="ConfirmarContrasena" class="config-form" asp-action="CambiarContrasena" asp-controller="Usuario" method="post">

                            <div class="row g-4">

                                <div class="col-12">
                                    <div class="form-floating">
                                        <input asp-for="Contrasena" type="password" id="Contrasena" class="form-control" placeholder="Contraseña nueva"/>
                                        <label>Contraseña nueva</label>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-floating">
                                        <input asp-for="ConfirmarContrasena" type="password" id="ConfirmarContrasena" class="form-control" placeholder="Confirmar contraseña"/>
                                        <label>Confirmar contraseña</label>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="contrasena-recomendacion p-3 rounded-3">
                                        <p class="contrasena-recomendacion-texto mb-0 small">
                                            <i class="fas fa-circle-info me-2"></i>
                                            La contraseña debe tener al menos 5 caracteres
                                            y contener un carácter especial.
                                        </p>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <button type="submit" class="btn btn-configuracion w-100">
                                        Cambiar contraseña
                                    </button>
                                </div>

                            </div>
                        </form>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>

<script src="~/js/configuracion.js"></script>
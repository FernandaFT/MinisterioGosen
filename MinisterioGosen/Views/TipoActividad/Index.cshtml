@model List<MinisterioGosen.Models.TipoActividadModel>

@{
    ViewData["Title"] = "Tipos de actividad";

    var tipos = Model ?? new List<MinisterioGosen.Models.TipoActividadModel>();
    var totalTipos = tipos.Count;
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-tags-fill me-2 text-primary"></i>
                Tipos de actividad
            </h2>
            <p class="text-muted mb-0">
                Administración de los tipos utilizados para clasificar las actividades.
            </p>
        </div>

        <a asp-controller="TipoActividad"
           asp-action="Crear"
           class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle-fill me-1"></i>
            Nuevo tipo
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                         style="width:48px;height:48px;">
                        <i class="bi bi-tags-fill text-primary fs-4"></i>
                    </div>

                    <div>
                        <p class="text-muted mb-0 small">Total registrados</p>
                        <h4 class="fw-bold mb-0">@totalTipos</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 px-4 pt-4 pb-2">
            <h5 class="fw-bold mb-0">
                <i class="bi bi-list-ul me-2 text-primary"></i>
                Listado de tipos de actividad
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">

                <table id="tablaTipoActividad"
                       data-datatable
                       class="table table-hover align-middle mb-0 w-100">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Código</th>
                            <th>Nombre del tipo</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (tipos.Any())
                        {
                            foreach (var item in tipos)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold">
                                        <span class="badge rounded-pill bg-secondary px-3 py-2">
                                            #@item.Id_Tipo_Actividad
                                        </span>
                                    </td>

                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                                                 style="width:34px;height:34px;min-width:34px;">
                                                <i class="bi bi-tag-fill text-primary"></i>
                                            </div>

                                            <span class="fw-semibold">@item.Nombre_Tipo</span>
                                        </div>
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="TipoActividad"
                                               asp-action="Editar"
                                               asp-route-id="@item.Id_Tipo_Actividad"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <a asp-controller="TipoActividad"
                                               asp-action="Eliminar"
                                               asp-route-id="@item.Id_Tipo_Actividad"
                                               class="btn btn-sm btn-outline-danger"
                                               title="Eliminar">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5">
                                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>

                                    <h5 class="fw-bold text-muted mt-3 mb-1">
                                        No hay tipos de actividad registrados
                                    </h5>

                                    <p class="text-muted mb-3">
                                        Cuando se creen tipos de actividad, aparecerán en este listado.
                                    </p>

                                    <a asp-controller="TipoActividad"
                                       asp-action="Crear"
                                       class="btn btn-primary rounded-pill px-4">
                                        <i class="bi bi-plus-circle-fill me-1"></i>
                                        Crear tipo
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
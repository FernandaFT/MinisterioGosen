@model MinisterioGosen.Models.TipoActividadModel

@{
    ViewData["Title"] = "Nuevo tipo de actividad";
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-plus-circle-fill me-2 text-primary"></i>
                Nuevo tipo de actividad
            </h2>
            <p class="text-muted mb-0">
                Registre un nuevo tipo para clasificar las actividades.
            </p>
        </div>

        <a asp-controller="TipoActividad"
           asp-action="Index"
           class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i>
            Volver
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-warning d-flex align-items-center gap-2 rounded-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.Mensaje</span>
                </div>
            }

            <div id="mensajeValidacion" class="alert alert-danger d-none">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                <span id="textoValidacion"></span>
            </div>

            <form asp-action="Crear"
                  asp-controller="TipoActividad"
                  method="post"
                  id="formTipoActividad"
                  novalidate>

                <div class="row g-4">

                    <div class="col-md-8">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-tag-fill me-1 text-muted"></i>
                            Nombre del tipo
                        </label>

                        <input asp-for="Nombre_Tipo"
                               class="form-control rounded-3"
                               placeholder="Ejemplo: Reunión, Taller, Capacitación" />

                        <div class="invalid-feedback">
                            Debe ingresar el nombre del tipo de actividad.
                        </div>
                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-controller="TipoActividad"
                       asp-action="Index"
                       class="btn btn-outline-secondary rounded-pill px-4">
                        Cancelar
                    </a>

                    <button type="submit"
                            class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-save-fill me-1"></i>
                        Guardar tipo
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/tipoactividad.js" asp-append-version="true"></script>
}